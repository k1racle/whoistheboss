<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= siteName %></title>
  <meta name="description" content="Скоро открытие">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body class="bg-site-gray text-gray-900 h-screen w-screen overflow-hidden flex flex-col">
  <main class="flex-1 flex items-center justify-center p-6 md:p-12">
    <img src="<%= logo %>" alt="<%= siteName %>" class="w-full max-w-4xl h-auto">
  </main>

  <div class="fixed bottom-0 left-0 right-0 bg-terracotta text-white py-4 md:py-5 overflow-hidden">
    <div class="marquee-track whitespace-nowrap flex">
      <% for (let i = 0; i < 4; i++) { %>
      <span class="marquee text-lg md:text-2xl lg:text-3xl uppercase tracking-widest px-8 md:px-12"><%= marquee %></span>
      <% } %>
    </div>
  </div>
</body>
</html>
