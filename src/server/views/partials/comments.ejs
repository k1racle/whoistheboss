<section class="py-16 bg-gray-50 border-t border-gray-100">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-3 mb-8">
      <h2 class="text-2xl font-bold section-title">Комментарии</h2>
      <% if (typeof commentCount !== 'undefined') { %>
      <span class="px-2.5 py-0.5 bg-terracotta/10 text-terracotta text-sm font-medium rounded-full"><%= commentCount %></span>
      <% } %>
    </div>

    <% if (user) { %>
    <form action="/api/comments" method="POST" class="mb-10 card p-6">
      <input type="hidden" name="<%= type %>Id" value="<%= itemId %>">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Ваш комментарий</label>
        <textarea name="content" rows="4" required minlength="3" maxlength="2000" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-terracotta focus:border-transparent transition-shadow bg-gray-50"></textarea>
      </div>
      <button type="submit" class="btn-primary">Отправить</button>
    </form>
    <% } else { %>
    <div class="mb-10 card p-6">
      <p class="text-gray-600"><a href="/login?returnTo=<%= encodeURIComponent(path) %>" class="text-terracotta hover:underline font-medium">Войдите</a>, чтобы оставить комментарий.</p>
    </div>
    <% } %>

    <% if (comments.length) { %>
    <div class="space-y-6">
      <% comments.forEach((comment) => { %>
      <article class="card p-6">
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-gradient-to-br from-terracotta to-terracotta-600 text-white flex items-center justify-center text-sm font-bold">
              <%= comment.user.name.charAt(0).toUpperCase() %>
            </div>
            <span class="font-medium"><%= comment.user.name %></span>
          </div>
          <time class="text-sm text-gray-500" datetime="<%= comment.createdAt.toISOString() %>"><%= formatDate(comment.createdAt) %></time>
        </div>
        <p class="text-gray-700 leading-relaxed"><%= comment.content %></p>
      </article>
      <% }) %>
    </div>
    <% } else { %>
    <p class="text-gray-500">Пока нет комментариев. Будьте первым!</p>
    <% } %>
  </div>
</section>
