<%- include('../partials/header', { title, description, siteName, siteDescription }) %>

<article class="pt-24 md:pt-32 pb-16 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <header class="mb-10 animate-on-scroll">
      <p class="text-terracotta font-semibold mb-4"><a href="/blog" class="hover:underline">← Все материалы</a></p>
      <h1 class="text-3xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-5 leading-tight"><%= article.title %></h1>
      <% if (article.subtitle) { %>
      <p class="text-xl md:text-2xl text-gray-600 mb-8 font-light"><%= article.subtitle %></p>
      <% } %>
      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
        <% if (article.entrepreneur) { %>
        <a href="/entrepreneurs/<%= article.entrepreneur.slug %>" class="font-semibold text-gray-900 hover:text-terracotta transition-colors"><%= article.entrepreneur.name %></a>
        <span>·</span>
        <% } %>
        <time datetime="<%= article.publishedAt?.toISOString() %>"><%= formatDate(article.publishedAt) %></time>
      </div>
    </header>

    <% if (article.coverImage) { %>
    <div class="aspect-video bg-gray-100 overflow-hidden mb-12 rounded-2xl shadow-xl animate-on-scroll img-zoom">
      <img src="<%= article.coverImage %>" alt="<%= article.title %>" class="w-full h-full object-cover">
    </div>
    <% } %>

    <div class="animate-on-scroll article-content text-gray-800 leading-relaxed">
      <%- article.content %>
    </div>

    <div class="mt-12">
      <%- include('../partials/engagement', {
        type: 'ARTICLE',
        itemId: article.id,
        engagement: engagement,
        path: `/blog/${article.slug}`,
        title: article.title,
        siteUrl: siteUrl
      }) %>
    </div>
  </div>
</article>

<% if (related.length) { %>
<section class="py-20 bg-gray-50 border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-extrabold mb-10 animate-on-scroll section-title">Ещё материалы</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <% related.forEach((item, index) => { %>
      <article class="animate-on-scroll card overflow-hidden group" style="transition-delay: <%= index * 100 %>ms">
        <a href="/blog/<%= item.slug %>" class="block aspect-video bg-gray-100 overflow-hidden img-zoom">
          <img src="<%= item.coverImage || '/images/placeholder.jpg' %>" alt="<%= item.title %>" class="w-full h-full object-cover">
        </a>
        <div class="p-6">
          <p class="text-xs text-gray-500 mb-3 uppercase tracking-wider"><%= formatDate(item.publishedAt) %></p>
          <h3 class="font-bold text-lg mb-2 group-hover:text-terracotta transition-colors leading-tight"><a href="/blog/<%= item.slug %>"><%= item.title %></a></h3>
        </div>
      </article>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<%- include('../partials/comments', {
  comments: article.comments,
  commentCount: article._count.comments,
  type: 'article',
  itemId: article.id,
  path: `/blog/${article.slug}`,
  user: user,
  formatDate: formatDate
}) %>

<%- include('../partials/footer', { siteName, siteDescription }) %>
