<%- include('../partials/header', { title, description, siteName, siteDescription }) %>

<section class="py-24 md:py-32 bg-gray-50">
  <div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8">
    <div class="card p-8 animate-on-scroll">
      <h1 class="text-3xl font-extrabold mb-2 text-center">Регистрация</h1>
      <p class="text-gray-500 text-center mb-8">Присоединяйтесь к сообществу</p>
      <% if (error) { %>
      <div class="bg-red-50 text-red-700 p-4 mb-6 rounded-xl text-sm">Ошибка регистрации. Возможно, email уже занят.</div>
      <% } %>
      <form action="/api/auth/register" method="POST" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Имя</label>
          <input type="text" name="name" required class="input">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input type="email" name="email" required class="input">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Пароль</label>
          <input type="password" name="password" required minlength="6" class="input">
        </div>
        <button type="submit" class="btn-primary w-full">Зарегистрироваться</button>
      </form>
      <p class="mt-6 text-center text-sm text-gray-600">Уже есть аккаунт? <a href="/login" class="text-terracotta hover:underline font-medium">Войти</a></p>
    </div>
  </div>
</section>

<%- include('../partials/footer', { siteName, siteDescription }) %>
