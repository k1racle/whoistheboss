<%- include('../partials/header', { title, description, siteName, siteDescription }) %>

<section class="py-24 md:py-32 bg-gray-50">
  <div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8">
    <div class="card p-8 animate-on-scroll">
      <h1 class="text-3xl font-extrabold mb-2 text-center">Вход</h1>
      <p class="text-gray-500 text-center mb-8">Снова в деле</p>
      <% if (error) { %>
      <div class="bg-red-50 text-red-700 p-4 mb-6 rounded-xl text-sm">Ошибка входа. Проверьте email и пароль.</div>
      <% } %>
      <form action="/api/auth/login" method="POST" class="space-y-5">
        <input type="hidden" name="returnTo" value="<%= typeof returnTo !== 'undefined' ? returnTo : '' %>">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input type="email" name="email" required class="input">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Пароль</label>
          <input type="password" name="password" required class="input">
        </div>
        <button type="submit" class="btn-primary w-full">Войти</button>
      </form>
      <p class="mt-6 text-center text-sm text-gray-600">Нет аккаунта? <a href="/register" class="text-terracotta hover:underline font-medium">Зарегистрироваться</a></p>
    </div>
  </div>
</section>

<%- include('../partials/footer', { siteName, siteDescription }) %>
