<%- include('../partials/header', { title, description, siteName, siteDescription }) %>

<article class="pt-24 md:pt-32 pb-16 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <header class="mb-12 animate-on-scroll">
      <p class="text-terracotta font-semibold mb-4"><a href="/interviews" class="hover:underline">← Все интервью</a></p>
      <h1 class="text-3xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-5 leading-tight"><%= interview.title %></h1>
      <% if (interview.subtitle) { %>
      <p class="text-xl md:text-2xl text-gray-600 mb-8 font-light"><%= interview.subtitle %></p>
      <% } %>
      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
        <% if (interview.entrepreneur) { %>
        <a href="/entrepreneurs/<%= interview.entrepreneur.slug %>" class="font-semibold text-gray-900 hover:text-terracotta transition-colors"><%= interview.entrepreneur.name %></a>
        <span>·</span>
        <span><%= interview.entrepreneur.title %></span>
        <span>·</span>
        <% } %>
        <time datetime="<%= interview.publishedAt?.toISOString() %>"><%= formatDate(interview.publishedAt) %></time>
      </div>
    </header>

    <% if (interview.videoUrl || interview.videoFile) { %>
    <div class="aspect-video bg-gray-900 mb-12 overflow-hidden rounded-2xl shadow-2xl animate-on-scroll img-zoom">
      <% if (interview.videoType === 'EMBED') { %>
      <iframe src="<%= interview.videoUrl %>" class="w-full h-full" frameborder="0" allowfullscreen title="<%= interview.title %>"></iframe>
      <% } else { %>
      <video src="<%= interview.videoFile %>" controls class="w-full h-full"></video>
      <% } %>
    </div>
    <% } %>

    <% if (interview.quote) { %>
    <blockquote class="animate-on-scroll text-2xl md:text-3xl font-light italic text-gray-900 my-12 pl-8 border-l-4 border-terracotta leading-snug">
      «<%= interview.quote %>»
    </blockquote>
    <% } %>

    <% if (interview.summary) { %>
    <p class="animate-on-scroll text-xl text-gray-700 mb-10 leading-relaxed font-light"><%= interview.summary %></p>
    <% } %>

    <div class="animate-on-scroll article-content text-gray-800 leading-relaxed">
      <%- interview.content %>
    </div>

    <div class="mt-12">
      <%- include('../partials/engagement', {
        type: 'INTERVIEW',
        itemId: interview.id,
        engagement: engagement,
        path: `/interviews/${interview.slug}`,
        title: interview.title,
        siteUrl: siteUrl
      }) %>
    </div>
  </div>
</article>

<% if (related.length) { %>
<section class="py-20 bg-gray-50 border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-extrabold mb-10 animate-on-scroll section-title">Ещё интервью</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% related.forEach((item, index) => { %>
      <article class="animate-on-scroll card overflow-hidden group" style="transition-delay: <%= index * 100 %>ms">
        <a href="/interviews/<%= item.slug %>" class="block aspect-video bg-gray-100 overflow-hidden img-zoom">
          <img src="<%= item.entrepreneur?.photo || item.coverImage || '/images/placeholder.jpg' %>" alt="<%= item.entrepreneur?.name %>" class="w-full h-full object-cover">
        </a>
        <div class="p-6">
          <h3 class="font-bold text-lg mb-1 group-hover:text-terracotta transition-colors"><a href="/interviews/<%= item.slug %>"><%= item.entrepreneur?.name || item.title %></a></h3>
          <p class="text-sm text-gray-500"><%= item.entrepreneur?.title %></p>
        </div>
      </article>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<%- include('../partials/comments', {
  comments: interview.comments,
  commentCount: interview._count.comments,
  type: 'interview',
  itemId: interview.id,
  path: `/interviews/${interview.slug}`,
  user: user,
  formatDate: formatDate
}) %>

<%- include('../partials/footer', { siteName, siteDescription }) %>
