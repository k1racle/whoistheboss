<%- include('../partials/header', { title, description, siteName, siteDescription }) %>

<section class="py-24 md:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mb-14 animate-on-scroll">
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-4 section-title">Коротко. Рилсы</h1>
      <p class="text-xl text-gray-600 leading-relaxed">Быстрые истории и инсайты от предпринимателей.</p>
    </div>

    <% if (reels.length) { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <% reels.forEach((item, index) => { %>
      <article class="animate-on-scroll card overflow-hidden group" style="transition-delay: <%= index * 100 %>ms">
        <a href="/reels/<%= item.slug %>" class="block relative aspect-reel bg-gray-900 overflow-hidden img-zoom">
          <img src="<%= item.coverImage || item.entrepreneur?.photo || '/images/placeholder.jpg' %>" alt="<%= item.entrepreneur?.name %>" class="w-full h-full object-cover opacity-90 group-hover:scale-105 transition-transform duration-500 blur-[2px]">
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-16 h-16 rounded-full bg-white/95 flex items-center justify-center group-hover:bg-terracotta group-hover:text-white transition-all duration-300 group-hover:scale-110 shadow-lg">
              <svg class="w-7 h-7 ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
        </a>
        <div class="p-6">
          <h2 class="font-bold text-lg group-hover:text-terracotta transition-colors"><a href="/reels/<%= item.slug %>"><%= item.title %></a></h2>
        </div>
      </article>
      <% }) %>
    </div>
    <% } else { %>
    <p class="text-gray-500 animate-on-scroll">Пока нет опубликованных рилсов.</p>
    <% } %>
  </div>
</section>

<%- include('../partials/footer', { siteName, siteDescription }) %>
