<%- include('partials/header', { title, description, siteName, siteDescription }) %>

<section class="py-20 md:py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 animate-on-scroll">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 section-title inline-block">Контакты</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">Свяжитесь с нами удобным способом или оставьте заявку на съёмку.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
      <div class="card p-8 animate-on-scroll">
        <h2 class="text-2xl font-bold mb-6">Как с нами связаться</h2>
        <div class="space-y-5">
          <% if (address) { %>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-terracotta/10 flex items-center justify-center shrink-0 text-terracotta">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <p class="text-sm text-gray-500 mb-1">Адрес</p>
              <p class="text-gray-900 whitespace-pre-line"><%= address %></p>
            </div>
          </div>
          <% } %>

          <% if (phone) { %>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-terracotta/10 flex items-center justify-center shrink-0 text-terracotta">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <p class="text-sm text-gray-500 mb-1">Телефон</p>
              <a href="tel:<%= phone.replace(/\s/g, '') %>" class="text-gray-900 hover:text-terracotta transition-colors"><%= phone %></a>
            </div>
          </div>
          <% } %>

          <% if (email) { %>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-terracotta/10 flex items-center justify-center shrink-0 text-terracotta">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p class="text-sm text-gray-500 mb-1">Email</p>
              <a href="mailto:<%= email %>" class="text-gray-900 hover:text-terracotta transition-colors"><%= email %></a>
            </div>
          </div>
          <% } %>
        </div>

        <div class="mt-8 pt-8 border-t border-gray-100">
          <p class="text-sm text-gray-500 mb-3">Мы в соцсетях</p>
          <%- include('partials/social-links', { social: typeof social !== 'undefined' ? social : {}, iconClass: 'text-gray-600 hover:text-terracotta transition-colors' }) %>
        </div>
      </div>

      <% if (mapEmbed) { %>
      <div class="card overflow-hidden animate-on-scroll">
        <iframe src="<%= mapEmbed %>" width="100%" height="100%" style="min-height: 360px; border: 0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Карта"></iframe>
      </div>
      <% } else { %>
      <div class="card p-8 flex items-center justify-center text-gray-400 animate-on-scroll">
        <p>Добавьте ссылку на карту в настройках админки.</p>
      </div>
      <% } %>
    </div>

    <div class="max-w-3xl mx-auto">
      <div class="card p-8 animate-on-scroll">
        <h2 class="text-2xl font-bold mb-2 text-center">Заявка на съёмку</h2>
        <p class="text-gray-600 text-center mb-8">Расскажите о вашем бизнесе, и мы свяжемся для обсуждения проекта.</p>

        <% if (success) { %>
        <div class="bg-green-50 border border-green-200 text-green-800 p-6 rounded-xl mb-8">
          Спасибо! Ваша заявка принята. Мы свяжемся с вами в ближайшее время.
        </div>
        <% } %>

        <% if (error) { %>
        <div class="bg-red-50 border border-red-200 text-red-800 p-6 rounded-xl mb-8">
          Произошла ошибка. Проверьте введённые данные и попробуйте снова.
        </div>
        <% } %>

        <form action="/api/shooting-request" method="POST" class="space-y-6">
          <input type="hidden" name="redirect" value="/contacts?success=1">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Имя *</label>
            <input type="text" id="name" name="name" required class="input">
          </div>
          <div>
            <label for="company" class="block text-sm font-medium text-gray-700 mb-1">Компания</label>
            <input type="text" id="company" name="company" class="input">
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
              <input type="email" id="email" name="email" required class="input">
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Телефон</label>
              <input type="tel" id="phone" name="phone" class="input">
            </div>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">О проекте</label>
            <textarea id="message" name="message" rows="5" class="input"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full md:w-auto">Отправить заявку</button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer', { siteName, siteDescription }) %>
