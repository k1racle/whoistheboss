{
  "name": "guessboss",
  "version": "1.0.0",
  "description": "Медиа-портал «Кто здесь главный?»",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:admin\" \"npm run watch:css\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:admin": "vite --config vite.config.ts",
    "watch:css": "tailwindcss -i src/server/styles/main.css -o public/css/main.css --watch",
    "build": "npm run build:css && npm run build:admin && npm run build:server && npm run copy:views",
    "copy:views": "rm -rf dist/server/views && cp -r src/server/views dist/server/views",
    "build:server": "tsc -p tsconfig.json",
    "build:admin": "vite build --config vite.config.ts",
    "build:css": "tailwindcss -i src/server/styles/main.css -o public/css/main.css --minify",
    "start": "node dist/server/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "@types/quill": "^2.0.14",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "connect-pg-simple": "^9.0.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.3.1",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "prisma": "^5.15.0",
    "quill": "^2.0.3",
    "sharp": "^0.33.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "@types/nodemailer": "^6.4.15",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
